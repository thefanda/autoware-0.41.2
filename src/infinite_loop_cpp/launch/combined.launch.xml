<launch>
  <arg name="config_file" default="$(find-pkg-share infinite_loop_cpp)/config/infinite_loop.yaml"/>

  <node pkg="infinite_loop_cpp" exec="infinite_loop_node" name="infinite_loop_node" output="screen">
    <param from="$(var config_file)"/>
  </node>

  <node pkg="infinite_loop_cpp" exec="map_parser_node" name="map_parser_node" output="screen"/>
</launch>
