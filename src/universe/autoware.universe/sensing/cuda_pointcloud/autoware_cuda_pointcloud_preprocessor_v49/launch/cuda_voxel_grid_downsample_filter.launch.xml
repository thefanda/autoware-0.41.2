<launch>
  <arg name="input/pointcloud" default="/sensing/lidar/concatenated/pointcloud"/>
  <arg name="output/pointcloud" default="/sensing/lidar/top/downsampled"/>
  <arg name="debug" default="false">
    <choice value="true"/>
    <choice value="false"/>
  </arg>

  <arg name="cuda_voxel_gird_downsample_filter_param_file" default="$(find-pkg-share autoware_cuda_pointcloud_preprocessor_v49)/config/cuda_voxel_grid_downsample_filter.param.yaml"/>

  <node pkg="autoware_cuda_pointcloud_preprocessor_v49" exec="cuda_voxel_grid_downsample_filter_node_v49" name="cuda_voxel_grid_downsample_filter_v49" output="screen" unless="$(var debug)">
    <remap from="~/input/pointcloud" to="$(var input/pointcloud)"/>
    <remap from="~/output/pointcloud" to="$(var output/pointcloud)"/>
    <param from="$(var cuda_voxel_gird_downsample_filter_param_file)"/>
  </node>

  <node
    pkg="autoware_cuda_pointcloud_preprocessor_v49"
    exec="cuda_voxel_grid_downsample_filter_node_v49"
    name="cuda_voxel_grid_downsample_filter_v49"
    output="screen"
    launch-prefix="gnome-terminal -- cuda-gdb --args"
    if="$(var debug)"
  >
    <remap from="~/input/pointcloud" to="$(var input/pointcloud)"/>
    <remap from="~/output/pointcloud" to="$(var output/pointcloud)"/>
    <param from="$(var cuda_voxel_gird_downsample_filter_param_file)"/>
  </node>
</launch>
