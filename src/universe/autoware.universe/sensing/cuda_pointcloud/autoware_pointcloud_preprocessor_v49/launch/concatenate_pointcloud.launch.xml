<launch>
  <arg name="output" default="/sensing/lidar/concatenated/pointcloud"/>
  <arg name="output_info" default="/sensing/lidar/concatenated/pointcloud_info"/>
  <!-- Parameter -->
  <arg name="param_file" default="$(find-pkg-share autoware_pointcloud_preprocessor_v49)/config/concatenate_pointclouds.param.yaml"/>
  <node pkg="autoware_pointcloud_preprocessor_v49" exec="concatenate_pointclouds_node_v49" name="concatenate_pointclouds_node_v49" output="screen">
    <remap from="output" to="$(var output)"/>
    <remap from="output_info" to="$(var output_info)"/>
    <param from="$(var param_file)"/>
  </node>
</launch>
